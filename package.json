{
  "name": "impl-server-policy-summarizer",
  "private": true,
  "workspaces": [
    "workspace/apps/*"
  ],
  "scripts": {
    "lint": "oxlint --react-plugin --import-plugin workspace/apps",
    "lint:fix": "oxlint --fix --react-plugin --import-plugin workspace/apps",
    "fmt": "oxfmt workspace/apps",
    "fmt:check": "oxfmt --check workspace/apps",
    "typecheck": "bun run typecheck:server && bun run typecheck:ui",
    "typecheck:server": "tsc -p workspace/apps/server/tsconfig.json --noEmit",
    "typecheck:ui": "tsc -p workspace/apps/ui/tsconfig.json --noEmit",
    "build:ui": "bun run --cwd workspace/apps/ui build",
    "dev:ui": "bun run --cwd workspace/apps/ui dev",
    "preview:server": "bun run --cwd workspace/apps/server preview",
    "test:server": "bun run --cwd workspace/apps/server test",
    "dev:server": "bun run --cwd workspace/apps/server dev",
    "start:server": "bun run --cwd workspace/apps/server start",
    "dev:all": "concurrently -n ui,server -c blue,green \"bun run --cwd workspace/apps/ui dev\" \"bun run --cwd workspace/apps/server dev\"",
    "generate:all": "concurrently -n ui,server -c blue,green \"bun run --cwd workspace/apps/server generate:all\" \"bun run --cwd workspace/apps/ui generate:all\""
  },
  "devDependencies": {
    "@rsbuild/core": "1.7.4",
    "@rsbuild/plugin-react": "^1.4.6",
    "@types/bun": "1.3.11",
    "@types/node": "25.5.0",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2"
  }
}
