{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../../tsconfig.node.json",
  "compilerOptions": {
    "paths": {
      "@utilities/*": ["./src/core/utilities/*"],
      "@services/*": ["./src/core/services/*"],
      "@persistence/*": ["./src/persistence/*"],
      "@features/*": ["./src/features/*"],
      "@configs/*": ["./src/configs/*"],
      "@clients/*": ["./src/clients/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
